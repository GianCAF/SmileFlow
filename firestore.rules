rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function devAccessOpen() {
      return request.time < timestamp.date(2026, 7, 3);
    }

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc().data.role == 'admin';
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if devAccessOpen() && (isAdmin() || isOwner(userId));
      allow create: if devAccessOpen() && isOwner(userId);
      allow update: if devAccessOpen() && (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role));
      allow delete: if devAccessOpen() && isAdmin();
    }

    match /clinicAvailability/{dayKey} {
      allow read: if devAccessOpen();
      allow write: if devAccessOpen() && isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if devAccessOpen() && (isAdmin() || (signedIn() && resource.data.patientUid == request.auth.uid));
      allow create: if devAccessOpen() && (isAdmin() || (signedIn() && request.resource.data.patientUid == request.auth.uid));
      allow update: if devAccessOpen() && (
        isAdmin()
        || (
          signedIn()
          && resource.data.patientUid == request.auth.uid
          && request.resource.data.patientUid == resource.data.patientUid
          && request.resource.data.status == resource.data.status
        )
      );
      allow delete: if devAccessOpen() && isAdmin();
    }
  }
}
