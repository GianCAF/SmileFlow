PORT=4000
CLIENT_ORIGIN=http://localhost:5173
DEFAULT_COUNTRY_CODE=52

# Para desarrollo puedes arrancar primero sin WhatsApp y activar despues.
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./session

# Firestore Admin. Opcion A: credencial completa en base64.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Opcion B: campos separados.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

REMINDERS_ENABLED=true
REMINDER_CRON=0 * * * *

CLINIC_LOCATION_MESSAGE=Estamos en Av. Sonrisa 123. Puedes pedir una cita aqui mismo.
CLINIC_PRICES_MESSAGE=Con gusto te compartimos precios. Limpieza desde $700 MXN y valoracion inicial con agenda previa.
